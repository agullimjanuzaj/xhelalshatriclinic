# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xhelal_shatri_clinic"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=xhelal_shatri_clinic

# ==========================================
# BACKEND (NestJS)
# ==========================================
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ==========================================
# FRONTEND (Next.js)
# ==========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=super_secret_nextauth_key_change_in_production_min_32_chars

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Xhelal Shatri Clinic"

# ==========================================
# EMAIL (opsionale)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Xhelal Shatri Clinic <noreply@xhelalshatri.com>"

# ==========================================
# UPLOADS
# ==========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
